# Optional defaults for ablation runs. Source this file or export the values
# before running ablations/run_ablation.sh.

# Where ablation outputs are written. The default is:
#   ${OUTPUT_DIR}/ablations/<dataset>/<variant>
ABLATION_ROOT_DIR=/root/brjverl/data_gradual_new/outputs/ablations

# For the uniform_count variant only. Leave empty to use the rounded mean of
# the original per-seed target_count values.
ABLATION_UNIFORM_COUNT=

# Usual stage controls are still honored by the reused stage scripts.
STAGE_VLLM_MODE=managed
STAGE_FORCE=0
STAGE_RESUME=1
