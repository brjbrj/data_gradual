# Independent model-evaluation defaults. Copy to evaluation/eval.env for
# machine-specific changes. Command-line environment variables still override
# values from these files.

# Input and output.
EVAL_INPUT_PATH=/root/brjverl/datas/gsm8k_2.jsonl
EVAL_OUTPUT_DIR=/root/brjverl/data_gradual_new/outputs/model_eval/gsm8k_2
EVAL_FORMAT_TEMPLATE=auto
EVAL_ANSWER_EXTRACT_MODE=number
EVAL_PROMPT_PATH=/root/brjverl/data_gradual_new/evaluation/prompt/generate.json

# Model and OpenAI-compatible vLLM endpoint.
EVAL_MODEL=/root/brjverl/models/Qwen3.6-27B
EVAL_BASE_URL=http://127.0.0.1:8911/v1
EVAL_API_KEY=EMPTY

# Sampling and request behavior.
EVAL_N_ANSWERS=1
EVAL_CONCURRENCY=64
EVAL_TEMPERATURE=0.0
EVAL_TOP_P=0.95
EVAL_MAX_TOKENS=1500
EVAL_PRESENCE_PENALTY=0.0
EVAL_FREQUENCY_PENALTY=0.0
EVAL_PROMPT_MODE=legacy_concat
EVAL_ATTEMPT_VARIATION=0
EVAL_SEED_BASE=
EVAL_TIMEOUT=600
EVAL_MAX_RETRIES=-1
EVAL_RESUME=1
