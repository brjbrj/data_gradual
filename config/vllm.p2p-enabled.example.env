# Merge these values into config/pipeline.env on machines where native GPU P2P
# works and forcing NCCL to loopback/P2P-disabled mode causes startup hangs.
VLLM_GPU_MEMORY_UTILIZATION=0.85
VLLM_ENFORCE_EAGER=1
VLLM_DISABLE_CUSTOM_ALL_REDUCE=0
VLLM_ENABLE_AUTO_TOOL_CHOICE=0

VLLM_CUDA_VISIBLE_DEVICES=0,1
VLLM_NCCL_IB_DISABLE=1
VLLM_NCCL_P2P_DISABLE=unset
VLLM_NCCL_DEBUG=unset
VLLM_NCCL_SOCKET_IFNAME=unset
VLLM_NCCL_BLOCKING_WAIT=unset
VLLM_TORCH_NCCL_BLOCKING_WAIT=unset
VLLM_NCCL_ALGO=unset
VLLM_NCCL_P2P_LEVEL=unset
VLLM_NCCL_PXN_DISABLE=unset
VLLM_NCCL_CUMEM_ENABLE=unset
VLLM_GLOO_SOCKET_IFNAME=unset
VLLM_HOST_IP_CONFIG=unset
