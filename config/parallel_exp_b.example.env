# Overlay config for a second concurrent experiment.
# Usage:
#   PIPELINE_CONFIG_FILE=config/parallel_exp_b.example.env bash run/run_stage_sequence.sh gsm8k
#
# This file is loaded after config/pipeline.env, so only values that differ
# from the base machine config need to be set here.

PIPELINE_CONDA_ENV=brj
VLLM_CONDA_ENV=brj

VLLM_RUNTIME_MODE=managed
VLLM_BASE_URL=http://127.0.0.1:8912/v1
VLLM_API_PORT=8912

# Use a separate output and runtime directory so generated files, PID files,
# model markers, and logs cannot collide with another experiment.
OUTPUT_DIR=/jizhicfs/hymiezhao/lpc/repos/brj/data_gradual_new/outputs_exp_b
VLLM_PID_FILE=/jizhicfs/hymiezhao/lpc/repos/brj/data_gradual_new/outputs_exp_b/runtime/vllm/vllm.pid
VLLM_LOG_FILE=/jizhicfs/hymiezhao/lpc/repos/brj/data_gradual_new/outputs_exp_b/runtime/vllm/vllm.log

# Choose non-overlapping GPUs if two vLLM servers run at the same time.
VLLM_CUDA_VISIBLE_DEVICES=2,3
VLLM_TP=2
STAGE_VLLM_STOP_ON_EXIT=1
