VLLM_NCCL_CUMEM_ENABLE=inherit
VLLM_GLOO_SOCKET_IFNAME=inherit
VLLM_HOST_IP_CONFIG=inherit

VLLM_ATTENTION_BACKEND=XFORMERS
VLLM_USE_FLASH_ATTN=0
VLLM_USE_FLASHINFER=0
FLASHINFER_DISABLE_JIT=1
VLLM_USE_V1=0
VLLM_EXPECTED_VERSION=0.19.0

