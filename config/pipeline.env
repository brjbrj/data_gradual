VLLM_TIMEOUT=600
VLLM_MAX_RETRIES=2

VLLM_CUDA_VISIBLE_DEVICES=0,1,2,3
VLLM_NCCL_DEBUG=INFO
VLLM_NCCL_BLOCKING_WAIT=1
