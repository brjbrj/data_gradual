CONDA_SH=/root/miniconda3/etc/profile.d/conda.sh
PIPELINE_CONDA_ENV=brj
PIPELINE_PYTHON=
VLLM_CONDA_ENV=qwen
VLLM_PYTHON=

VLLM_MODEL=/root/brjverl/models/Qwen3.6-27B
VLLM_BASE_URL=http://127.0.0.1:8911/v1
VLLM_API_KEY=EMPTY
# managed: the pipeline starts, stops, and switches vLLM automatically while
# every model uses the same configured API port. external remains optional.
VLLM_RUNTIME_MODE=managed
VLLM_START_TIMEOUT=600
VLLM_START_POLL_SEC=5
# Use -1 to wait indefinitely while you switch models on the same endpoint.
VLLM_EXTERNAL_WAIT_TIMEOUT=-1
VLLM_EXTERNAL_POLL_SEC=5
# Foreground manual launches can still mirror output into this log file.
VLLM_LOG_FILE=/root/brjverl/data_gradual_new/outputs/runtime/vllm.log
VLLM_FOREGROUND_LOG=1
VLLM_LOG_APPEND=0
VLLM_HOST=0.0.0.0
# Fixed external OpenAI-compatible API port. Do not use VLLM_PORT here:
# vLLM 0.8.x also interprets that name as an internal worker-port setting.
VLLM_API_PORT=8911
VLLM_TP=2
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_ENABLE_AUTO_TOOL_CHOICE=1
VLLM_TOOL_CALL_PARSER=hermes
VLLM_ENFORCE_EAGER=0
VLLM_DISABLE_CUSTOM_ALL_REDUCE=0
VLLM_TIMEOUT=600
VLLM_MAX_RETRIES=2

# vLLM multi-GPU environment. Values support:
# - a normal value: export the variable
# - unset: explicitly remove the variable
# - inherit: preserve the parent process value
VLLM_CUDA_VISIBLE_DEVICES=0,1
VLLM_NCCL_P2P_DISABLE=1
VLLM_NCCL_IB_DISABLE=1
VLLM_NCCL_DEBUG=INFO
VLLM_NCCL_SOCKET_IFNAME=lo
VLLM_NCCL_BLOCKING_WAIT=1
VLLM_TORCH_NCCL_BLOCKING_WAIT=inherit
VLLM_NCCL_ALGO=inherit
VLLM_NCCL_P2P_LEVEL=inherit
VLLM_NCCL_PXN_DISABLE=inherit
VLLM_NCCL_CUMEM_ENABLE=inherit
VLLM_GLOO_SOCKET_IFNAME=inherit
VLLM_HOST_IP_CONFIG=inherit
VICTIM_MODEL=/root/brjverl/models/Meta-Llama-3-8B-Instruct
STEP_MODEL=/root/brjverl/models/Qwen3.6-27B
QC_MODEL=/root/brjverl/models/Qwen3.6-27B
GEN_MODEL=/root/brjverl/models/Qwen3.6-27B
REPAIR_MODEL=/root/brjverl/models/Qwen3.6-27B
GEN_MAX_RETRIES=3
GEN_MAX_TOKENS=640
GEN_FORCE_JSON=0
GEN_ENABLE_THINKING=0
GEN_SIMILARITY_THRESHOLD=0.88
GEN_ROUND_RETRY_DELAY=1
GEN_CONCURRENCY_CAP=256
VICTIM_TEMPERATURE=0.3
VICTIM_TOP_P=0.95
ANSWER_CONCURRENCY=256
SCORE_CONCURRENCY=256
SCORE_ENABLE_THINKING=0
SCORE_FORCE_JSON=1
SCORE_DEDUPLICATE=1
SCORE_RESUME=1
SCORE_MAX_RETRIES=3
SCORE_RETRY_DELAY=1
SCORE_PROGRESS_EVERY=5
SCORE_PROGRESS_INTERVAL=5
SCORE_FALLBACK_ON_EXHAUSTED=1
SCORE_MIN_TOKENS=900
SCORE_TOKENS_PER_STEP=64
SCORE_MAX_TOKENS=900
GEN_CONCURRENCY=256
QC_CONCURRENCY=256
RUN_VALIDATION=1
QC_BLIND_VOTES=2
QC_TIEBREAK_VOTES=1
QC_MAX_ROUNDS=3
QC_MAX_TOKENS=900
QC_ENABLE_THINKING=0
QC_FORCE_JSON=0
QC_ROUND_RETRY_DELAY=1
QC_PROGRESS_EVERY=10
QC_PROGRESS_INTERVAL=10
QC_REPLAN_AFTER=3
QC_REPLAN_AFTER_RETRY_ERRORS=3
GEN_TEMPERATURE=0.5
GEN_TOP_P=0.5
GEN_TEMPERATURE_MAP={"Easy":0.3,"Slightly Easy":0.4,"Equal":0.5,"Slightly Hard":0.6,"Hard":0.7}
GEN_TOP_P_MAP={"Easy":0.3,"Slightly Easy":0.4,"Equal":0.5,"Slightly Hard":0.6,"Hard":0.7}
SYNTHESIS_TARGET_MULTIPLIER=26
SYNTHESIS_MIN_PER_SEED=10
SYNTHESIS_MAX_PER_SEED=50
SYNTHESIS_BALANCE_LAMBDA=0.3
INPUT_PATH=/root/brjverl/data_gradual_new/data/gsm8k.jsonl
OUTPUT_DIR=/root/brjverl/data_gradual_new/outputs
